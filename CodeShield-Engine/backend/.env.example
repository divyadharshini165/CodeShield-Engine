# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/codeshield_db

# Express server port
PORT=5000

# JWT signing secret -- change this to a long random value in production
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# One-time secret used by POST /api/auth/make-admin to bootstrap the very
# first admin account. Change this, then remove/rotate it after initial setup.
ADMIN_PROMOTION_SECRET=replace_with_a_long_random_secret

# Redis connection URL (required for async queue + Socket.io live grading)
# If unset or Redis is unreachable, submissions are graded synchronously (fallback).
REDIS_URL=redis://127.0.0.1:6379

# Docker runner image name (built from backend/docker/Dockerfile)
# If the image doesn't exist, execution falls back to direct subprocess mode.
DOCKER_RUNNER_IMAGE=codeshield-runner

# Docker memory cap per submission container
DOCKER_MEMORY_LIMIT=256m

# Worker concurrency (how many submissions can be graded in parallel per worker process)
SUBMISSION_WORKER_CONCURRENCY=2

# Set to "true" to disable the in-process BullMQ worker so you can run
# `node queue/submissionWorker.js` as separate scaled-out processes instead.
SKIP_INPROCESS_WORKER=false

# Local Ollama AI sub-system (Tier 4: Hint Generator + Code Review)
# Start Ollama:  ollama serve
# Pull a model:  ollama pull deepseek-r1:1.5b
# If Ollama is not running, AI features gracefully degrade with a 503 response.
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
OLLAMA_MODEL=deepseek-r1:1.5b
OLLAMA_CONNECT_TIMEOUT_MS=8000
